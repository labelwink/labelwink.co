# LabelWink — Environment Variables Template
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Razorpay (NO Stripe, NO COD) ─────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Cloudinary ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Shiprocket ────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ── SendGrid (email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── MSG91 (SMS/OTP) ───────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── Meilisearch (search) ──────────────────────────────────────────────────────
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# ── PostHog (analytics) ───────────────────────────────────────────────────────
POSTHOG_KEY=

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin (legacy JWT — will be replaced by Supabase auth) ───────────────────
ADMIN_PASSWORD=
JWT_SECRET=
